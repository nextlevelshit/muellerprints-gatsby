{
	"name": "muellerprints",
	"version": "1.0.0",
	"private": true,
	"description": "MUELLERPRINTS.",
	"author": "Michael Czechowski",
	"scripts": {
		"start": "gatsby develop",
		"clean": "gatsby clean",
		"serve": "gatsby serve",
		"build": "gatsby build --prefix-paths && cp public/sitemap.xml/sitemap-index.xml public/sitemap.xml",
		"publish": "git add . && git commit -am \"Content update\" && git push"
	},
	"dependencies": {
		"@mdx-js/mdx": "^1.6.22",
		"@mdx-js/react": "^1.6.22",
		"babel-plugin-styled-components": "^2.0.2",
		"dotenv": "^17.2.3",
		"gatsby": "^4.25.9",
		"gatsby-plugin-image": "^2.25.0",
		"gatsby-plugin-manifest": "^4.25.0",
		"gatsby-plugin-mdx": "^3.20.0",
		"gatsby-plugin-page-creator": "^4.25.0",
		"gatsby-plugin-react-helmet": "^5.25.0",
		"gatsby-plugin-sharp": "^4.25.0",
		"gatsby-plugin-sitemap": "^5.25.0",
		"gatsby-plugin-styled-components": "^5.25.0",
		"gatsby-source-filesystem": "^4.25.0",
		"gatsby-transformer-sharp": "^4.25.0",
		"gh-pages": "^6.1.1",
		"nodemailer": "^7.0.12",
		"prettier": "^2.5.1",
		"react": "^17.0.2",
		"react-dom": "^17.0.2",
		"react-helmet": "^6.1.0",
		"react-is": "^18.2.0",
		"remark-disable-tokenizers": "^1.1.0",
		"sharp": "^0.34.5",
		"slug": "^5.3.0",
		"styled-components": "^5.3.3"
	},
	"prettier": {
		"useTabs": true,
		"tabWidth": 4,
		"semi": false,
		"singleQuote": false,
		"bracketSpacing": true,
		"arrowParens": "always",
		"printWidth": 160
	},
	"devDependencies": {
		"baseline-browser-mapping": "^2.9.11",
		"node-gyp": "^12.1.0",
		"prop-types": "^15.8.1"
	}
}
